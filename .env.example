# Базовый URL API (без слеша в конце)
# Прод:        https://api.blumteam.ru
# Локально с прокси через vite.config.ts: http://localhost:3000
# Локальный бэк напрямую:                 http://localhost:8000
VITE_API_BASE_URL=http://localhost:3000

# Таймаут axios-запросов в миллисекундах
VITE_API_TIMEOUT=10000
